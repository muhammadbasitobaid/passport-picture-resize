# Port the service listens on
PORT=7001
# rembg model name used for background removal
BG_MODEL=birefnet-general-lite
# Comma-separated allowed CORS origins (the Next.js app). Use * for any.
ALLOWED_ORIGINS=http://localhost:5173
# Reject uploads larger than this many bytes (default 15 MiB)
MAX_UPLOAD_BYTES=15728640
